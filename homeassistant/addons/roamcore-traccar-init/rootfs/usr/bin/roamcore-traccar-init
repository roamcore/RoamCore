#!/usr/bin/env bash
set -euo pipefail

CONFIG_PATH="/data/options.json"
SECRETS="/config/secrets.yaml"

log() { echo "[roamcore-traccar-init] $*"; }

get_json() {
  # jq supports nested keys via dot notation.
  local key="$1"
  jq -r ".${key}" "$CONFIG_PATH" 2>/dev/null
}

if ! command -v jq >/dev/null 2>&1; then
  log "ERROR: jq not found; cannot parse options.json"
  exit 1
fi

TRACCAR_BASE_URL=$(get_json traccar_base_url)
TRACCAR_ADDON_SLUG=$(get_json traccar_addon_slug)
ADMIN_EMAIL=$(get_json admin_email)
KEY_EMAIL=$(get_json secrets_keys.email)
KEY_PASS=$(get_json secrets_keys.password)
PASS_LEN=$(get_json password_length)
WAIT_TIMEOUT=$(get_json wait_timeout_seconds)

if [ -z "${TRACCAR_BASE_URL}" ]; then
  log "ERROR: traccar_base_url empty"
  exit 1
fi

mkdir -p "$(dirname "$SECRETS")"
touch "$SECRETS"
chmod 600 "$SECRETS" || true

has_key() {
  local k="$1"
  grep -Eqs "^${k}:" "$SECRETS"
}

# If already provisioned, exit cleanly.
if has_key "$KEY_EMAIL" && has_key "$KEY_PASS"; then
  log "Secrets already present in secrets.yaml (${KEY_EMAIL}, ${KEY_PASS}); nothing to do."
  exit 0
fi

# Generate password + persist first (so we never lose it even if Traccar create fails)
PASS=$(openssl rand -base64 64 | tr -d '\n' | tr -dc 'A-Za-z0-9' | head -c "${PASS_LEN}")

# Append secrets if missing
if ! has_key "$KEY_EMAIL"; then
  echo "${KEY_EMAIL}: \"${ADMIN_EMAIL}\"" >> "$SECRETS"
fi
if ! has_key "$KEY_PASS"; then
  echo "${KEY_PASS}: \"${PASS}\"" >> "$SECRETS"
fi

log "Wrote Traccar admin secrets to /config/secrets.yaml (keys: ${KEY_EMAIL}, ${KEY_PASS})."

SUP_TOKEN=""
if [ -f /run/supervisor_token ]; then
  SUP_TOKEN=$(cat /run/supervisor_token 2>/dev/null || true)
fi

sup_post() {
  # Best-effort Supervisor API helper
  local path="$1"
  if [ -z "$SUP_TOKEN" ]; then
    return 1
  fi
  curl -fsS -H "Authorization: Bearer ${SUP_TOKEN}" -H 'Content-Type: application/json' \
    -X POST "http://supervisor${path}" -d '{}' >/dev/null
}

sup_stop_traccar() {
  [ -n "${TRACCAR_ADDON_SLUG}" ] || return 1
  sup_post "/addons/${TRACCAR_ADDON_SLUG}/stop" || return 1
}

sup_start_traccar() {
  [ -n "${TRACCAR_ADDON_SLUG}" ] || return 1
  sup_post "/addons/${TRACCAR_ADDON_SLUG}/start" || return 1
}

# Wait for Traccar health
start=$(date +%s)
while true; do
  if curl -fsS "${TRACCAR_BASE_URL%/}/api/health" >/dev/null 2>&1; then
    break
  fi
  now=$(date +%s)
  if [ $((now-start)) -ge "$WAIT_TIMEOUT" ]; then
    log "WARN: Timed out waiting for Traccar at ${TRACCAR_BASE_URL}. Secrets written; user creation not attempted."
    exit 0
  fi
  sleep 2
done

log "Attempting zero-manual provisioning (stop Traccar, seed DB, restart)"

# Stop Traccar to unlock H2 database
if ! sup_stop_traccar; then
  log "WARN: Could not stop Traccar via Supervisor API. Falling back to manual signup."
  exit 0
fi

# Give it a moment to stop
sleep 3

# Seed H2 database with an admin user (idempotent: no-op if user exists)
# Traccar uses PBKDF2WithHmacSHA1 (iter=1000), 24-byte salt and 24-byte hash.
HASH_SALT=$(python3 - <<PY
import os, binascii, hashlib
password='${PASS}'.encode('utf-8')
salt=os.urandom(24)
h=hashlib.pbkdf2_hmac('sha1', password, salt, 1000, dklen=24)
print(binascii.hexlify(h).decode())
print(binascii.hexlify(salt).decode())
PY
)
HASH=$(echo "$HASH_SALT" | head -n1)
SALT=$(echo "$HASH_SALT" | tail -n1)

SQL=$(cat <<EOF
-- Create RoamCore admin user if missing
-- NOTE: This expects Traccar default H2 schema (USERS table with password/salt hex).
MERGE INTO users (id, name, email, password, salt, administrator, readonly, deviceReadonly, limitCommands, disabled)
KEY(email)
VALUES (
  COALESCE((SELECT MAX(id) + 1 FROM users), 1),
  'RoamCore Admin',
  '${ADMIN_EMAIL}',
  '${HASH}',
  '${SALT}',
  TRUE,
  FALSE,
  FALSE,
  FALSE,
  FALSE
);
EOF
)

if ! java -cp /opt/traccar/lib/h2-2.2.224.jar org.h2.tools.RunScript -url jdbc:h2:/data/traccar -user sa -password "" -script /dev/stdin <<EOS
$SQL
EOS
then
  log "WARN: DB seed failed. Traccar will require manual signup, but secrets remain stored."
fi

# Restart Traccar
sup_start_traccar || true
log "Provisioning complete (best-effort)."
exit 0
