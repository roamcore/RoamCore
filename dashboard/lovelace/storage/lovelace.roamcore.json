        {
          "title": "Overview",
          "path": "overview",
          "icon": "mdi:view-dashboard",
          "type": "sections",
          "max_columns": 4,
          "sections": [
            {
              "type": "grid",
              "cards": [
                {
                  "type": "custom:roamcore-power-tile"
                },
                {
                  "type": "custom:roamcore-network-tile"
                }
              ]
            },
            {
              "type": "grid",
              "cards": [
                {
                  "type": "custom:roamcore-level-tile"
                },
                {
                  "type": "custom:roamcore-map-tile"
                }
              ]
            }
          ]
        },
        {
          "title": "Power",
          "path": "power",
          "icon": "mdi:flash",
          "type": "sections",
          "max_columns": 3,
          "sections": [
            {
              "type": "grid",
              "cards": [
                {
                  "type": "custom:roamcore-power-page"
                }
              ]
            }
          ]
        },
        {
          "title": "Network",
          "path": "network",
          "icon": "mdi:wifi",
          "type": "sections",
          "max_columns": 3,
          "sections": [
            {
              "type": "grid",
              "cards": [
                {
                  "type": "custom:roamcore-network-page"
                }
              ]
            }
          ]
        },
        {
          "title": "Level",
          "path": "level",
          "icon": "mdi:slope-downhill",
