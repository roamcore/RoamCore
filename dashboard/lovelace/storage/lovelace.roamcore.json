          "max_columns": 3,
          "sections": [
            {
              "type": "grid",
              "cards": [
                {
                  "type": "custom:roamcore-level-page"
                }
              ]
            }
          ],
          "cards": []
        },
        {
          "title": "Map",
          "path": "map",
          "icon": "mdi:map",
          "type": "sections",
          "max_columns": 3,
          "sections": [
            {
              "type": "grid",
              "cards": [
                {
                  "type": "custom:roamcore-map-page"
                }
              ]
            }
          ]
        },
        {
          "title": "MVP",
          "path": "mvp",
          "icon": "mdi:rocket",
          "type": "sections",
          "max_columns": 3,
          "sections": [
            {
              "type": "grid",
              "cards": [
                {
                  "type": "entities",
                  "title": "Weather / Time (rc_*)",
                  "show_header_toggle": false,
                  "entities": [
                    "sensor.rc_time_local",
                    "sensor.rc_time_zone",
                    "input_text.rc_time_zone_override",
                    "input_text.rc_weather_entity_id",
                    "sensor.rc_weather_temp_c",
                    "sensor.rc_weather_condition"
                  ]
                },
                {
                  "type": "entities",
                  "title": "Location (rc_*)",
                  "show_header_toggle": false,
                  "entities": [
                    "input_text.rc_location_tracker_entity",
                    "sensor.rc_location_source",
                    "sensor.rc_location_lat",
                    "sensor.rc_location_lon",
                    "sensor.rc_location_accuracy_m",
                    "sensor.rc_location_speed",
                    "sensor.rc_location_heading_deg"
                  ]
                }
              ]
            },
            {
              "type": "grid",
              "cards": [
                {
                  "type": "entities",
                  "title": "Trip Wrapped (MVP)",
                  "show_header_toggle": false,
                  "entities": [
                    "input_text.rc_traccar_base_url",
                    "input_number.rc_traccar_device_id",
                    "input_text.rc_trip_wrapped_from",
                    "input_text.rc_trip_wrapped_to",
                    "script.rc_trip_wrapped_run"
                  ]
                },
                {
                  "type": "markdown",
                  "content": "## Trip Wrapped output\nOpen: `/local/roamcore/trip_wrapped/latest.html`\n\nIf the page is blank, set Traccar creds + device id above and tap **Generate**."
                }
              ]
            },
            {
              "type": "grid",
              "cards": [
                {
                  "type": "entities",
                  "title": "Setup Wizard (scaffold)",
                  "show_header_toggle": false,
                  "entities": [
                    "input_boolean.roamcore_setup_complete",
                    "input_boolean.roamcore_wifi_enable",
                    "input_text.roamcore_wifi_ssid",
                    "input_select.roamcore_wan_mode",
                    "input_boolean.roamcore_victron_enable",
                    "input_select.roamcore_victron_method",
                    "input_text.roamcore_victron_host",
                    "input_number.roamcore_victron_port",
                    "input_select.roamcore_timezone",
                    "script.roamcore_setup_apply_timezone",
                    "script.roamcore_setup_complete"
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  }
