# RoamCore OpenWrt Netstack — example variables
# Copy to vars.env (do not commit vars.env) and override as needed.

# --- LAN ---
RC_LAN_IP="10.0.0.1"
RC_LAN_NETMASK="255.255.255.0"
RC_LAN_DHCP_START="100"
RC_LAN_DHCP_LIMIT="100"
RC_LAN_DHCP_LEASETIME="12h"

# --- Local DNS ---
RC_DOMAIN="local"
RC_DNS_ROAMCORE_NAME="roamcore.local"
RC_DNS_ROAMCORE_IP="10.0.0.1"
RC_DNS_HA_NAME="ha.roamcore.local"
RC_DNS_HA_IP="10.0.0.10"

# --- Home Assistant DHCP reservation (optional) ---
# Leave empty to skip.
RC_HA_STATIC_MAC=""
RC_HA_STATIC_IP="10.0.0.10"

# --- Wi‑Fi defaults (MVP placeholders; change during setup wizard) ---
RC_WIFI_SSID="RoamCore"
RC_WIFI_KEY="roamcore-default"
RC_WIFI_COUNTRY="GB"
RC_WIFI_CHANNEL_2G="6"
RC_WIFI_CHANNEL_5G="36"

# --- WAN interface device names (OpenWrt-side) ---
# In the final product, these should map to:
#   Starlink WAN: eth1
#   LAN bridge NIC: eth0
#   LTE data: wwan0 (QMI)
RC_DEV_LAN="eth0"
RC_DEV_WAN_STARLINK="eth1"
RC_DEV_WAN_LTE_WWAN="wwan0"
RC_DEV_LTE_QMI="/dev/cdc-wdm0"

# --- WAN preference ---
# starlink|lte
RC_WAN_PREFERRED="starlink"

