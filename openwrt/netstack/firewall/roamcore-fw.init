#!/bin/sh /etc/rc.common
# RoamCore firewall workaround service

START=19
STOP=89
USE_PROCD=1

start_service() {
  procd_open_instance
  procd_set_param command /bin/sh -c "/opt/roamcore/iptables_mvp.sh"
  procd_set_param respawn 0 0 0
  procd_close_instance
}

reload_service() {
  /opt/roamcore/iptables_mvp.sh || true
}

